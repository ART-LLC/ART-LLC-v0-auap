{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "pnpm install",
  "buildCommand": "pnpm build",
  "outputDirectory": ".next",
  "env": {
    "NEXTAUTH_URL": "@auapw_nextauth_url",
    "NEXTAUTH_SECRET": "@auapw_nextauth_secret",
    "DATABASE_URL": "@auapw_database_url",
    "STRIPE_SECRET_KEY": "@auapw_stripe_secret_key",
    "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY": "@auapw_stripe_publishable_key",
    "SENDGRID_API_KEY": "@auapw_sendgrid_api_key",
    "NEXT_PUBLIC_APP_URL": "@auapw_app_url"
  },
  "regions": ["sfo1"],
  "functions": {
    "app/api/**": {
      "maxDuration": 60
    }
  },
  "redirects": [
    {
      "source": "/parts",
      "destination": "/products",
      "permanent": true
    },
    {
      "source": "/catalog",
      "destination": "/products",
      "permanent": true
    }
  ]
}
